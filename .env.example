# XorazmDelivery — muhit o'zgaruvchilari
# Ushbu faylni .env ga nusxalang va qiymatlarni to'ldiring

# ── Ma'lumotlar bazasi ─────────────────────────────────────────
DB_PASSWORD=xd_secret_2024

# ── Eskiz.uz SMS ──────────────────────────────────────────────
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your_eskiz_password

# ── Click to'lov ──────────────────────────────────────────────
CLICK_MERCHANT_ID=12345
CLICK_SERVICE_ID=67890
CLICK_SECRET_KEY=your_click_secret

# ── Payme to'lov ──────────────────────────────────────────────
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_SECRET_KEY=your_payme_key

# ── MinIO fayl saqlash ────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PASSWORD=admin_password

